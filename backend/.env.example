# Ejemplo de variables de entorno para el backend
# Sustituye los valores por credenciales reales en tu entorno local/producción

# URL de conexión a la base de datos. Ejemplo MySQL con PyMySQL:
DATABASE_URL=mysql://USER:PASSWORD@HOST:3306/DB_NAME

# Identidad de la app/instancia para health checks y logs
APP_NAME=registro_produccion
APP_INSTANCE=indufor
APP_ENV=production
APP_VERSION=unknown
LOG_LEVEL=info

# Clave secreta para firma de tokens (cámbiala en producción)
SECRET_KEY=change-me-in-production-with-a-real-secret-key

# Horas de expiración del token de acceso
ACCESS_TOKEN_EXPIRE_HOURS=8

# Orígenes permitidos CORS (se pueden separar por comas)
# Ejemplo: http://localhost:5173,http://localhost:5174
ALLOWED_ORIGINS=
